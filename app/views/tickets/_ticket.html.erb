<div id="<%= dom_id ticket %>">
  <p>
    <strong>Title:</strong>
    <%= ticket.title %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= ticket.description %>
  </p>

  <p>
    <strong>Event type:</strong>
    <%= ticket.event_type %>
  </p>

  <p>
  <strong>Event date:</strong>
  <%= ticket.date %>
</p>

</div>
