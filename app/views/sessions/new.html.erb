<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
</head>

<body>
  <div class="login-container">
    <h2>Log In</h2>

    <%= form_with url: login_path, method: :post, data: { turbo: false } do %>
      <div class="form-group">
        <%= label_tag :email %>
        <%= email_field_tag :email, nil, required: true, placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= label_tag :password %>
        <%= password_field_tag :password, nil, required: true, minlength: 6 %>
      </div>

      <%= submit_tag "Log In", class: "login-button" %>
    <% end %>

    <p style="margin-top: 1rem;">
      New here?
      <%= link_to "Create an account", signup_path, class: "nav-link" %>
    </p>
  </div>
</body>
</html>
